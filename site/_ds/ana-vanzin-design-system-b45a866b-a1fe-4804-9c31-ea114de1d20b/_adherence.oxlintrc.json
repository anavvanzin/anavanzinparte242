{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "atlas/**",
              "brand/**",
              "components/content/**",
              "components/core/**",
              "components/desktop/**",
              "components/site/**",
              "design_handoff_anavanzin_site/pages/**",
              "design_handoff_research_wing/reference/**",
              "desktop-app.js",
              "hifi/**",
              "icons.js",
              "manifesto/**",
              "site/**",
              "site/atlas/**",
              "site_lite/**",
              "ui_kits/desktop/**",
              "ui_kits/website/**",
              "uploads/**",
              "window-contents.js"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Hanken Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Hanken Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='BlindfoldHero'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|subtitle|lede|animate|style|key|ref|className|style|children)$/]",
        "message": "<BlindfoldHero> doesn't accept that prop. Declared props: name, subtitle, lede, animate, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|solid|quiet)$/]",
        "message": "<Button> variant must be one of 'outline' | 'solid' | 'quiet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DesktopIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|selected|onSelect|onOpen|width|style|key|ref|className|style|children)$/]",
        "message": "<DesktopIcon> doesn't accept that prop. Declared props: icon, label, selected, onSelect, onOpen, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DockItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|title|active|minimized|key|ref|className|style|children)$/]",
        "message": "<DockItem> doesn't accept that prop. Declared props: id, title, active, minimized."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|as|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, color, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:rubric|ink|muted)$/]",
        "message": "<Eyebrow> color must be one of 'rubric' | 'ink' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FootnoteRef'] > JSXAttribute > JSXIdentifier[name!=/^(?:n|style|key|ref|className|style|children)$/]",
        "message": "<FootnoteRef> doesn't accept that prop. Declared props: n, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|activeId|onSelect|lockupSrc|langToggle|style|key|ref|className|style|children)$/]",
        "message": "<NavBar> doesn't accept that prop. Declared props: items, activeId, onSelect, lockupSrc, langToggle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PublicationEntry'] > JSXAttribute > JSXIdentifier[name!=/^(?:year|title|href|meta|note|style|key|ref|className|style|children)$/]",
        "message": "<PublicationEntry> doesn't accept that prop. Declared props: year, title, href, meta, note, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RubricLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|children|external|style|key|ref|className|style|children)$/]",
        "message": "<RubricLink> doesn't accept that prop. Declared props: href, children, external, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionRule'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|lang|id|style|key|ref|className|style|children)$/]",
        "message": "<SectionRule> doesn't accept that prop. Declared props: eyebrow, title, lang, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteFooter'] > JSXAttribute > JSXIdentifier[name!=/^(?:sealSrc|email|lines|style|key|ref|className|style|children)$/]",
        "message": "<SiteFooter> doesn't accept that prop. Declared props: sealSrc, email, lines, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Window'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|active|width|onClose|onMinimize|onTitleDown|bodyPad|children|style|key|ref|className|style|children)$/]",
        "message": "<Window> doesn't accept that prop. Declared props: title, active, width, onClose, onMinimize, onTitleDown, bodyPad, children, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
